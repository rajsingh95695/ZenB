# Twitter Sentiment Analysis Platform - Environment Variables
# Copy this file to .env and fill in your values

# RapidAPI Twitter API Key (Required for fetching tweets)
# Get your free API key from: https://rapidapi.com/omarmhaimdat/api/twitter-api45
RAPIDAPI_KEY=your_api_key_here

# Database Configuration
DB_PASSWORD=admin123

# Grafana Dashboard Password
GRAFANA_PASSWORD=admin123

# Optional: Advanced Configuration
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
# PYTHONUNBUFFERED=1

# Optional: Monitoring
# PROMETHEUS_RETENTION_TIME=200h

# Optional: Nginx Configuration (if using SSL)
# SSL_CERT_PATH=./nginx/ssl/cert.pem
# SSL_KEY_PATH=./nginx/ssl/key.pem